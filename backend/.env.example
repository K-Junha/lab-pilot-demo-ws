# LAB PILOT Backend — 환경변수 예시
# 이 파일을 .env로 복사한 후 실제 값으로 채워서 사용

# JWT 서명 키 (필수 — 미설정 시 서버 시작 실패)
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this

# PostgreSQL 연결 문자열
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/labpilot

# CORS 허용 origin (쉼표 구분)
ALLOWED_ORIGINS=["http://localhost:9002"]

# 파일 경로
UPLOAD_PATH=./uploads
LOG_PATH=./logs

# ss_manager 인증 키 (manager.py --api-key 값과 동일하게 설정)
MANAGER_API_KEY=your-manager-api-key-here
